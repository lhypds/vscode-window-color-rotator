{
  "name": "vscode-color-rotator",
  "displayName": "VS Code Color Rotator",
  "publisher": "gcc3",
  "version": "1.0.0",
  "description": "Rotate VSCode window colors for different projects",
  "engines": {
    "vscode": "^1.60.0"
  },
  "main": "./dist/extension",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "vscode-color-rotator.rotate",
        "title": "Rotate Window Color"
      },
      {
        "command": "vscode-color-rotator.load",
        "title": "Reload Window Color"
      },
      {
        "command": "vscode-color-rotator.clear",
        "title": "Clear Window Color"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "build": "tsc -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/vscode": "^1.60.0",
    "prettier": "^3.8.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
